rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // VpnUser Validation
    function isValidVpnUser(data) {
      let required = data.keys().hasAll(['username']);
      let types = data.username is string && data.username.size() >= 3 && data.username.size() <= 64;
      let optional = (!('phone' in data) || (data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 20)) &&
                     (!('password_hash' in data) || data.password_hash is string) &&
                     (!('mode' in data) || data.mode in ['host', 'client', 'none']) &&
                     (!('status' in data) || data.status is string) &&
                     (!('is_active' in data) || data.is_active is bool) &&
                     (!('createdAt' in data) || data.createdAt is string || data.createdAt is timestamp) &&
                     (!('is_online' in data) || data.is_online is bool) &&
                     (!('is_public' in data) || data.is_public is bool) &&
                     (!('my_ip' in data) || (data.my_ip is string && data.my_ip.size() <= 45)) &&
                     (!('my_city' in data) || (data.my_city is string && data.my_city.size() <= 256)) &&
                     (!('my_isp' in data) || (data.my_isp is string && data.my_isp.size() <= 256)) &&
                     (!('device_model' in data) || (data.device_model is string && data.device_model.size() <= 256)) &&
                     (!('device_os' in data) || (data.device_os is string && data.device_os.size() <= 128)) &&
                     (!('wireguard_public_key' in data) || (data.wireguard_public_key is string && data.wireguard_public_key.size() <= 128)) &&
                     (!('last_seen' in data) || data.last_seen is string) &&
                     (!('country' in data) || (data.country is string && data.country.size() <= 128)) &&
                     (!('paired_with' in data) || (data.paired_with is string && data.paired_with.size() <= 64));
      return required && types && optional;
    }

    // User Collection Rules
    match /users/{username} {
      allow create: if isValidId(username) && isValidVpnUser(incoming()) && incoming().username == username;
      allow read: if true;
      allow update: if (
        // Action: Tunnel Update
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_online', 'last_seen', 'my_ip', 'my_city', 'my_isp', 'mode', 'wireguard_public_key', 'is_public']) ||
        // Action: Pairing Update
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paired_with'])
      );
    }

    // Chat Messages
    function isValidMessage(data) {
      return data.keys().hasAll(['from_username', 'to_username', 'message', 'message_type', 'created_at']) &&
             data.from_username is string &&
             data.to_username is string &&
             data.message is string && data.message.size() <= 2000 &&
             data.message_type in ['text', 'ip_share', 'pairing_code'];
    }

    match /chat_messages/{messageId} {
      allow create: if isValidMessage(incoming());
      allow read: if true; // In production, filter by from_username or to_username
    }

    // Pairing Tokens
    function isValidToken(data) {
      return data.keys().hasAll(['token_code', 'owner_username', 'expires_at']) &&
             data.token_code is string && data.token_code.size() == 6 &&
             data.owner_username is string &&
             data.expires_at is timestamp;
    }

    match /pairing_tokens/{tokenId} {
      allow create: if isValidId(tokenId) && isValidToken(incoming());
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_used', 'used_by']);
    }

    // App Stats
    match /stats/{statId} {
      allow read: if true;
      allow create, update: if isValidId(statId) && 
                              incoming().keys().hasAll(['stat_key', 'stat_value']) &&
                              incoming().stat_key == statId;
    }

    // Health Check
    match /test/connection {
      allow read: if true;
    }
  }
}
